# Downcity local Federation
PORT=3000
PUBLIC_URL=http://127.0.0.1:3000
DATABASE_PATH=./data/local.db
DOWNCITY_LOCAL_CITY_ID=vibecape
DOWNCITY_LOCAL_CITY_NAME=Vibecape
DOWNCITY_FEDERATION_ADMIN_SECRET_KEY=local-proxy-admin-secret

# CLIProxyAPI sidecar
CLIPROXY_HOST=127.0.0.1
CLIPROXY_PORT=8317
CLIPROXY_API_BASE_URL=http://127.0.0.1:8317/v1
CLIPROXY_API_KEY=downcity-local-proxy

# Model groups: codex, claude-code
DOWNCITY_LOCAL_MODELS=codex,claude-code

# Model specs use local_id=upstream_id or model_id.
DOWNCITY_CODEX_MODELS=codex-gpt-5-5=gpt-5.5,codex-gpt-5-codex=gpt-5-codex
DOWNCITY_CLAUDE_CODE_MODELS=claude-code-sonnet=claude-sonnet-4.6
